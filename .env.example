# 日志配置示例
# 将此文件保存为 .env 或在 docker-compose.yml 中配置

# ==================== 基础日志配置 ====================

# 日志级别选项：DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: 输出所有日志，包含详细的调试信息
# INFO:  输出一般性操作状态（生产环境推荐）
# WARNING: 只输出警告和错误信息
# ERROR: 只输出错误信息
# CRITICAL: 只输出严重错误

LOG_LEVEL=DEBUG

# ==================== 高级配置 ====================

# 禁用彩色输出（某些终端或日志收集系统可能需要）
# NO_COLOR=true

# 开启 DEBUG 模式（会影响其他功能，不仅仅是日志）
# DEBUG=true

# ==================== Docker 环境配置 ====================

# docker-compose.yml 示例：
# version: '3'
# services:
#   quark-auto-save:
#     image: ozoo0/quark-auto-save:latest
#     environment:
#       - LOG_LEVEL=DEBUG
#       - NO_COLOR=false
#     volumes:
#       - ./config:/app/config
#       - ./logs:/app/logs  # 可选：挂载日志目录

# ==================== 日志文件位置 ====================

# 默认情况下，日志会输出到：
# 1. 控制台（stdout）
# 2. 如果配置了日志文件路径，会写入文件

# 在代码中使用：
# from utils.logger import setup_logger
# logger = setup_logger(log_file="logs/app.log")

# ==================== 日志轮转配置 ====================

# 单个日志文件最大大小（字节）
# 默认：10MB (10*1024*1024)
# LOG_MAX_BYTES=10485760

# 保留的备份文件数量
# 默认：5 个
# LOG_BACKUP_COUNT=5

# ==================== 使用示例 ====================

# 开发环境：
export LOG_LEVEL=DEBUG

# 生产环境：
export LOG_LEVEL=INFO

# 仅查看错误：
export LOG_LEVEL=ERROR

# 调试特定问题：
export LOG_LEVEL=DEBUG
python quark_auto_save.py

# ==================== 日志分析命令 ====================

# 查看最近的错误
tail -f logs/app.log | grep ERROR

# 统计今天的日志数量
grep "$(date +%Y-%m-%d)" app.log | wc -l

# 查找特定任务的日志
grep "\[task_id=123\]" app.log

# 提取所有 WARNING 以上的日志
grep -E "\|(WARNING|ERROR|CRITICAL)\|" app.log
